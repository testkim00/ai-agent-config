{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.codex/feedback-loop/improvement-proposal.schema.json",
  "title": "Feedback Loop Improvement Proposal",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at",
    "source_summary",
    "proposal_items"
  ],
  "properties": {
    "schema_version": {
      "const": "feedback-loop-proposals/v1"
    },
    "generated_at": {
      "type": "string"
    },
    "source_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "report_schema_version",
        "window",
        "turns",
        "backlog_items"
      ],
      "properties": {
        "report_schema_version": {
          "type": "string"
        },
        "window": {
          "type": "object"
        },
        "turns": {
          "type": "integer",
          "minimum": 0
        },
        "backlog_items": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "proposal_items": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/proposalItem"
      }
    }
  },
  "$defs": {
    "candidatePath": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "mode",
        "reason"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "mode": {
          "enum": [
            "edit",
            "create"
          ]
        },
        "reason": {
          "type": "string"
        },
        "block_reason": {
          "type": "string"
        }
      }
    },
    "autoApplySummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "eligible",
        "scope",
        "safe_roots",
        "safe_candidate_paths",
        "blocked_candidate_paths"
      ],
      "properties": {
        "eligible": {
          "type": "boolean"
        },
        "scope": {
          "enum": [
            "local_config_only",
            "manual_only"
          ]
        },
        "safe_roots": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "safe_candidate_paths": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/candidatePath"
          }
        },
        "blocked_candidate_paths": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/candidatePath"
          }
        }
      }
    },
    "proposalItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "severity",
        "finding_code",
        "target",
        "action_type",
        "summary",
        "confidence",
        "candidate_paths",
        "implementation_notes",
        "evidence",
        "apply_prompt",
        "auto_apply"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "severity": {
          "enum": [
            "P1",
            "P2",
            "P3"
          ]
        },
        "finding_code": {
          "type": "string"
        },
        "target": {
          "enum": [
            "skill",
            "hook",
            "agent",
            "prompt",
            "script",
            "checklist",
            "docs"
          ]
        },
        "action_type": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "candidate_paths": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/candidatePath"
          }
        },
        "implementation_notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "apply_prompt": {
          "type": "string"
        },
        "auto_apply": {
          "$ref": "#/$defs/autoApplySummary"
        }
      }
    }
  }
}
