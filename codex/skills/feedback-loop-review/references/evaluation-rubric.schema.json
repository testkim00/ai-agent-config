{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.codex/feedback-loop/evaluation-rubric.schema.json",
  "title": "Feedback Loop Evaluation Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at",
    "window",
    "limitations",
    "summary",
    "improvement_backlog",
    "turn_evaluations"
  ],
  "properties": {
    "schema_version": {
      "const": "feedback-loop-evaluation/v1"
    },
    "generated_at": {
      "type": "string"
    },
    "window": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "events_dir"
      ],
      "properties": {
        "mode": {
          "enum": [
            "days",
            "date",
            "all_history"
          ]
        },
        "days": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "date": {
          "type": [
            "string",
            "null"
          ]
        },
        "session_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "events_dir": {
          "type": "string"
        },
        "files": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "recency_weighting": {
          "type": "object",
          "additionalProperties": {
            "type": "number"
          }
        },
        "feedback_filters": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "exclude_feedback_runs": {
              "type": "boolean"
            },
            "feedback_origin": {
              "type": [
                "string",
                "null"
              ]
            },
            "feedback_run_kind": {
              "type": [
                "string",
                "null"
              ]
            },
            "feedback_cycle_id": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        }
      }
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sessions",
        "turns",
        "high_risk_turns",
        "feedback_turns",
        "baseline_turns",
        "feedback_run_kinds",
        "feedback_origins",
        "turn_types",
        "recency_weighting",
        "findings_by_severity",
        "top_finding_codes"
      ],
      "properties": {
        "sessions": {
          "type": "integer",
          "minimum": 0
        },
        "turns": {
          "type": "integer",
          "minimum": 0
        },
        "high_risk_turns": {
          "type": "integer",
          "minimum": 0
        },
        "feedback_turns": {
          "type": "integer",
          "minimum": 0
        },
        "baseline_turns": {
          "type": "integer",
          "minimum": 0
        },
        "feedback_run_kinds": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "feedback_origins": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "turn_types": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "recency_weighting": {
          "type": "object",
          "additionalProperties": {
            "type": "number"
          }
        },
        "findings_by_severity": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "P1",
            "P2",
            "P3"
          ],
          "properties": {
            "P1": {
              "type": "integer",
              "minimum": 0
            },
            "P2": {
              "type": "integer",
              "minimum": 0
            },
            "P3": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "top_finding_codes": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "code",
              "count"
            ],
            "properties": {
              "code": {
                "type": "string"
              },
              "count": {
                "type": "integer",
                "minimum": 1
              }
            }
          }
        }
      }
    },
    "improvement_backlog": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/backlogItem"
      }
    },
    "turn_evaluations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/turnEvaluation"
      }
    }
  },
  "$defs": {
    "severity": {
      "enum": [
        "P1",
        "P2",
        "P3"
      ]
    },
    "target": {
      "enum": [
        "skill",
        "hook",
        "agent",
        "prompt",
        "script",
        "checklist",
        "docs"
      ]
    },
    "turnType": {
      "enum": [
        "analysis",
        "implementation",
        "bugfix",
        "refactor",
        "docs",
        "ops",
        "review"
      ]
    },
    "scoreEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "score",
        "rationale"
      ],
      "properties": {
        "score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 2
        },
        "rationale": {
          "type": "string"
        }
      }
    },
    "feedbackContext": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "is_feedback_run",
        "origin",
        "run_kind",
        "cycle_id",
        "experiment_id",
        "proposal_id"
      ],
      "properties": {
        "is_feedback_run": {
          "type": "boolean"
        },
        "origin": {
          "type": "string"
        },
        "run_kind": {
          "type": "string"
        },
        "cycle_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "experiment_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "proposal_id": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "severity",
        "title",
        "evidence",
        "impact",
        "suggested_action",
        "target",
        "confidence"
      ],
      "properties": {
        "code": {
          "type": "string"
        },
        "severity": {
          "$ref": "#/$defs/severity"
        },
        "title": {
          "type": "string"
        },
        "evidence": {
          "type": "string"
        },
        "impact": {
          "type": "string"
        },
        "suggested_action": {
          "type": "string"
        },
        "target": {
          "$ref": "#/$defs/target"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "backlogItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "severity",
        "target",
        "action_type",
        "suggested_action",
        "occurrences",
        "weighted_occurrences",
        "confidence"
      ],
      "properties": {
        "code": {
          "type": "string"
        },
        "severity": {
          "$ref": "#/$defs/severity"
        },
        "target": {
          "$ref": "#/$defs/target"
        },
        "action_type": {
          "type": "string"
        },
        "suggested_action": {
          "type": "string"
        },
        "occurrences": {
          "type": "integer",
          "minimum": 1
        },
        "weighted_occurrences": {
          "type": "number",
          "minimum": 0
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "example_turns": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "latest_seen_at": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "turnEvaluation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "session_id",
        "turn_id",
        "turn_type",
        "feedback_context",
        "latest_recorded_at",
        "age_days",
        "recency_weight",
        "overall_quality_score",
        "scores",
        "evidence",
        "findings"
      ],
      "properties": {
        "session_id": {
          "type": "string"
        },
        "turn_id": {
          "type": "string"
        },
        "turn_type": {
          "$ref": "#/$defs/turnType"
        },
        "feedback_context": {
          "$ref": "#/$defs/feedbackContext"
        },
        "latest_recorded_at": {
          "type": [
            "string",
            "null"
          ]
        },
        "age_days": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "recency_weight": {
          "type": "number",
          "minimum": 0
        },
        "overall_quality_score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "scores": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "task_focus",
            "verification",
            "efficiency",
            "recovery",
            "completion_discipline",
            "automation_potential"
          ],
          "properties": {
            "task_focus": {
              "$ref": "#/$defs/scoreEntry"
            },
            "verification": {
              "$ref": "#/$defs/scoreEntry"
            },
            "efficiency": {
              "$ref": "#/$defs/scoreEntry"
            },
            "recovery": {
              "$ref": "#/$defs/scoreEntry"
            },
            "completion_discipline": {
              "$ref": "#/$defs/scoreEntry"
            },
            "automation_potential": {
              "$ref": "#/$defs/scoreEntry"
            }
          }
        },
        "evidence": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "prompt_preview",
            "command_count",
            "validation_count",
            "failed_command_count",
            "command_categories",
            "repeated_commands",
            "artifact_paths",
            "transcript_paths"
          ],
          "properties": {
            "prompt_preview": {
              "type": [
                "string",
                "null"
              ]
            },
            "command_count": {
              "type": "integer",
              "minimum": 0
            },
            "validation_count": {
              "type": "integer",
              "minimum": 0
            },
            "failed_command_count": {
              "type": "integer",
              "minimum": 0
            },
            "command_categories": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "repeated_commands": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "final_message_preview": {
              "type": [
                "string",
                "null"
              ]
            },
            "artifact_paths": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "transcript_paths": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "findings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/finding"
          }
        }
      }
    }
  }
}
